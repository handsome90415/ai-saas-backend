# Backend Environment Variables
OPENAI_API_KEY=sk-your-openai-api-key
JWT_SECRET=your-jwt-secret-change-in-production
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_monthly

# App URL (used for Stripe checkout success/cancel/portal redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK (optional - for Firebase Auth verification)
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
